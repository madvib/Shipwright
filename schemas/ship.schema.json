{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/madvib/ship/main/schemas/ship.schema.json",
  "title": "Ship Project Manifest",
  "description": "Schema for .ship/ship.jsonc — the Ship project manifest that declares providers, modes, module identity, dependencies, and exports.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor autocompletion."
    },
    "schema_version": {
      "type": "string",
      "const": "1",
      "description": "Schema version. Currently '1'. Used for forward-compatible migrations."
    },
    "id": {
      "type": "string",
      "description": "Unique project identifier, auto-generated by `ship init`."
    },
    "project": {
      "type": "object",
      "description": "Project-level settings.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable project name."
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["claude", "cursor", "codex", "gemini", "opencode"]
          },
          "description": "AI provider targets for this project."
        },
        "provider_defaults": {
          "type": "object",
          "description": "Project-level provider settings inherited by all agents. Keys are provider names. Values validated against upstream provider schemas, with Ship-managed keys excluded. Agents override via provider_settings (deep merge, agent wins).",
          "properties": {
            "claude": {
              "allOf": [
                { "$ref": "https://www.schemastore.org/claude-code-settings.json" },
                {
                  "properties": {
                    "permissions": false,
                    "hooks": false,
                    "model": false,
                    "env": false,
                    "availableModels": false,
                    "maxCostPerSession": false,
                    "maxTurns": false,
                    "autoMemoryEnabled": false
                  }
                }
              ]
            },
            "codex": {
              "allOf": [
                { "$ref": "https://raw.githubusercontent.com/openai/codex/main/codex-rs/core/config.schema.json" },
                {
                  "properties": {
                    "model": false,
                    "mcp_servers": false
                  }
                }
              ]
            },
            "gemini": {
              "allOf": [
                { "$ref": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json" },
                {
                  "properties": {
                    "model": false,
                    "hooks": false,
                    "mcpServers": false
                  }
                }
              ]
            },
            "cursor": {
              "type": "object",
              "additionalProperties": true
            },
            "opencode": {
              "allOf": [
                { "$ref": "https://opencode.ai/config.json" },
                {
                  "properties": {
                    "model": false,
                    "mcp": false,
                    "permission": false
                  }
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ModeConfig" },
          "description": "Named modes that filter which MCP servers, skills, rules, and hooks are active. Selected per-workspace via `ship set-mode <id>`."
        },
        "skill_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["skills/"],
          "description": "Directories to scan for skills, relative to .ship/. Default: [\"skills/\"]. Each directory is searched for subdirectories containing a SKILL.md file. First path wins when duplicate skill IDs exist across paths."
        }
      },
      "additionalProperties": false
    },
    "module": {
      "type": "object",
      "description": "Package identity for registry publishing.",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Namespaced package path, e.g. github.com/owner/repo.",
          "pattern": "^[a-z0-9./_-]+$"
        },
        "version": {
          "type": "string",
          "description": "Semver version string (v-prefix optional).",
          "pattern": "^v?\\d+\\.\\d+\\.\\d+"
        },
        "description": {
          "type": "string",
          "description": "Human-readable package description."
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier, e.g. MIT, Apache-2.0."
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "description": "Registry dependencies. Keys are package paths (e.g. github.com/owner/repo), values are version constraints or objects with version and grant.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "description": "Version constraint shorthand, e.g. ^1.0.0 or main."
          },
          {
            "type": "object",
            "required": ["version"],
            "properties": {
              "version": {
                "type": "string",
                "description": "Version constraint, e.g. ^1.0.0, ~0.2, main."
              },
              "grant": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Tool permissions to grant this dependency."
              }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "exports": {
      "type": "object",
      "description": "Paths exported by this module for consumers.",
      "properties": {
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skill directory paths relative to .ship/, e.g. skills/my-skill. Each must contain a SKILL.md file."
        },
        "agents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Agent config file paths relative to .ship/, e.g. agents/my-agent.jsonc."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ModeConfig": {
      "type": "object",
      "required": ["id", "name"],
      "description": "A named mode that narrows the active configuration. Modes filter which resources are included in compiled output — they don't add, only restrict.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Machine-readable mode identifier.",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "description": "Human-readable mode name."
        },
        "description": {
          "type": "string",
          "description": "What this mode is for."
        },
        "mcp_servers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "MCP server IDs to include when this mode is active. Servers not listed are excluded from compiled output."
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skill IDs to include when this mode is active."
        },
        "rules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Rule IDs to include when this mode is active. Matched by filename stem (numeric prefix and .md suffix stripped)."
        },
        "permissions": {
          "type": "object",
          "description": "Permission overrides active only in this mode. Overlayed (additive) on top of the agent's permissions.",
          "properties": {
            "allow": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional tool patterns to allow in this mode."
            },
            "deny": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional tool patterns to deny in this mode."
            }
          },
          "additionalProperties": false
        },
        "target_agents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Override the project's providers list when this mode is active."
        }
      },
      "additionalProperties": false
    }
  }
}
