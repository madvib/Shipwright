{
  "$schema": "https://getship.dev/schemas/events.schema.json",
  "ship": ["annotation", "feedback", "artifact_created", "artifact_deleted"],
  "custom": [
    {
      "id": "page_created",
      "direction": "out",
      "label": "Page Created",
      "description": "Agent created a new brainstorm page. Each page is a standalone HTML artifact.",
      "schema": {
        "type": "object",
        "required": ["filename"],
        "properties": {
          "filename": { "type": "string" },
          "title": { "type": "string" },
          "iteration": { "type": "integer" }
        }
      }
    },
    {
      "id": "page_rejected",
      "direction": "in",
      "label": "Page Rejected",
      "description": "Human rejected a brainstorm page. Agent should create a new iteration.",
      "schema": {
        "type": "object",
        "required": ["filename"],
        "properties": {
          "filename": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  ]
}
