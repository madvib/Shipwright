{
  // Cloudflare agent
  "$schema": "../../schemas/agent.schema.json",
  "agent": {
    "id": "cloudflare",
    "name": "Cloudflare",
    "version": "0.1.0",
    "description": "Cloudflare Workers, D1, R2, KV, Durable Objects, Pages, wrangler config",
    "providers": ["claude"],
  },
  "skills": {
    "refs": [],
  },
  "mcp": {
    "servers": ["ship"],
  },
  "permissions": {
    "preset": "ship-autonomous",
    // Cloudflare infra changes are hard to reverse
    "tools_ask": ["Bash(wrangler deploy*)", "Bash(wrangler d1 execute*)", "Bash(npx wrangler*)"],
    "tools_deny": ["Bash(git push --force*)", "Bash(*cargo publish*)", "Bash(*npm publish*)"],
  },
  "rules": {
    "inline": "Your domain is Cloudflare infrastructure and bindings.\nDefault scope: apps/web/wrangler.toml, apps/web/src/server/, apps/web/worker*.\n\nThis project runs on Cloudflare Pages + Workers. DB is D1. Object storage is R2.\nPrefer Workers bindings over fetch() to internal services.\nD1 migrations go in drizzle/ — never hand-edit production schema.\nKV is for ephemeral/cache data only — not source of truth.\nTest D1 changes locally with `wrangler d1 execute --local` before proposing a migration.\nCloudflare infra mistakes are expensive to roll back — plan before making changes.\n\nFor app-level data model changes — create a job for react-architect or rust-runtime.",
  },
}
