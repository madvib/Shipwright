{
  // CLI Lane agent
  "$schema": "../../schemas/agent.schema.json",
  "agent": {
    "id": "cli-lane",
    "name": "CLI Lane — feat/cli-init",
    "version": "0.1.0",
    "description": "Active context for the CLI lane agent",
    "providers": ["claude", "codex", "cursor", "gemini", "opencode"],
  },
  "skills": {
    "refs": ["ship-coordination"],
  },
  "mcp": {
    "servers": [],
  },
  "plugins": {
    "install": [
      "rust-analyzer-lsp@claude-plugins-official",
    ],
    "scope": "project",
  },
  "permissions": {
    "preset": "ship-autonomous",
    "tools_deny": ["Bash(rm -rf *)", "Bash(git reset --hard*)"],
  },
  "rules": {
    "inline": "You are a CLI specialist working in apps/ship-studio-cli/. Stay within your file scope.\nOn session start: read .ship-session/job-spec.md — that is your full task context.\nWork autonomously. Don't ask clarifying questions — make decisions and note them.\nLog progress via append_job_log. Mark done via update_job when acceptance criteria are met.",
  },
}
