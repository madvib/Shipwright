{
  // gstack agent
  "$schema": "../../schemas/agent.schema.json",
  "agent": {
    "id": "gstack",
    "name": "gstack",
    "version": "0.1.0",
    "description": "QA, code review, retro, and design review skills from garrytan/gstack",
    "providers": ["claude"],
  },
  "skills": {
    "refs": [
      "github.com/garrytan/gstack/qa",
      "github.com/garrytan/gstack/review",
      "github.com/garrytan/gstack/retro",
      "github.com/garrytan/gstack/design-review",
      "github.com/garrytan/gstack/design-consultation",
      "github.com/garrytan/gstack/plan-ceo-review",
      "github.com/garrytan/gstack/plan-eng-review",
      "github.com/garrytan/gstack/plan-design-review",
      "github.com/garrytan/gstack/qa-only",
      "github.com/garrytan/gstack/browse",
      "github.com/garrytan/gstack/document-release",
      "github.com/garrytan/gstack/ship",
    ],
  },
  "mcp": {
    "servers": [],
  },
  "permissions": {
    "preset": "ship-standard",
  },
  "rules": {
    "inline": "You have access to gstack skills: /qa, /review, /retro, /design-review, /design-consultation,\n/plan-ceo-review, /plan-eng-review, /plan-design-review, /qa-only, /browse, /document-release.\n\nBrowse binary is at: ~/.claude/skills/gstack/browse/dist/browse",
  },
}
