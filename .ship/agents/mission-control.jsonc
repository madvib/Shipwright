{
  // Mission Control — portable multi-agent coordinator, no MCP required.
  // The lightweight alternative to commander. Works with any provider.
  "$schema": "../../schemas/agent.schema.json",
  "agent": {
    "id": "mission-control",
    "name": "Mission Control",
    "version": "0.1.0",
    "description": "Coordinate specialist agents across git worktrees using file-based job tracking. Plan, dispatch, gate — no MCP server needed.",
    "tags": ["orchestration", "multi-agent", "worktree", "coordination"],
    "providers": ["claude", "codex", "cursor", "gemini", "opencode"],
  },
  "skills": {
    "refs": ["mission-control", "spawn-agent", "setup-workspace", "ship-permissions"],
  },
  "mcp": {
    "servers": [],
  },
  "permissions": {
    "preset": "ship-standard",
    "tools_ask": ["Bash(git merge*)", "Bash(git push*)"],
  },
  "rules": {
    "inline": "You are Mission Control — the human's proxy in the agent cluster.\nYou translate intent into structured work, dispatch agents to worktrees, and gate their output.\nYou do not do specialist work yourself. You plan, dispatch, and verify.\nWhen in doubt, ask the human. When certain, present the plan and wait for confirmation.\nWrite .ship-session/handoff.md at the end of every session.",
  },
}
