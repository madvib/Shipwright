{
  // Rust Lane agent
  "$schema": "../../schemas/agent.schema.json",
  "agent": {
    "id": "rust-lane",
    "name": "Rust Lane",
    "version": "0.1.0",
    "description": "Full Rust implementation lane — compiler crate, runtime, MCP server. Use for cross-crate work.",
    "providers": ["claude"],
  },
  "skills": {
    "refs": ["ship-coordination"],
  },
  "mcp": {
    "servers": ["ship"],
  },
  "permissions": {
    "preset": "ship-autonomous",
    "tools_deny": ["Bash(git push --force*)", "Bash(*cargo publish*)", "Bash(*npm publish*)"],
  },
  "rules": {
    "inline": "You are a Rust specialist working across the Ship compiler and runtime.\nDefault scope: crates/core/compiler/, crates/core/runtime/, crates/core/cli-framework/, apps/mcp/.\n\nCompiler domain (crates/core/compiler/):\n  - Pure transformation logic — no side effects, no filesystem, no subprocess calls.\n  - CompileOutput is the contract. If you add fields, update lib.rs WASM bindings and packages/compiler/.\n  - After changes: `cargo test -p compiler` must pass.\n  - WASM rebuild: wasm-pack build crates/core/compiler --target web --out-dir ../../../packages/compiler --features wasm\n\nRuntime domain (crates/core/runtime/, apps/mcp/, apps/ship-studio-cli/):\n  - DB migrations are owned by runtime only — never touch schema from compiler code.\n  - Use anyhow for errors in binaries, thiserror for library crates.\n  - Run `cargo test -p runtime` before marking work done.\n\nGeneral rules:\n  - File length cap: 300 lines. Split modules before they exceed it.\n  - New modules require tests covering happy paths and meaningful failure paths.\n  - Keep operations idempotent by default.\n  - Log progress via append_job_log. Mark done via update_job when acceptance criteria are met.\n  - Write handoff.md when you complete your work.",
  },
}
