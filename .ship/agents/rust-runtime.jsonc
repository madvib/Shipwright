{
  // Rust Runtime agent
  "$schema": "../../schemas/agent.schema.json",
  "agent": {
    "id": "rust-runtime",
    "name": "Rust Runtime",
    "version": "0.1.0",
    "description": "Ship runtime, CLI, MCP server — Rust, sqlx, SQLite, platform architecture",
    "providers": ["claude"],
  },
  "skills": {
    "refs": ["ship-coordination"],
  },
  "mcp": {
    "servers": ["ship"],
  },
  "permissions": {
    "preset": "ship-autonomous",
    "tools_deny": ["Bash(git push --force*)", "Bash(*cargo publish*)", "Bash(*npm publish*)"],
  },
  "rules": {
    "inline": "Your domain is the Ship platform runtime, CLI, and MCP server.\nDefault scope: crates/core/runtime/, crates/core/cli-framework/, apps/mcp/, apps/ship-studio-cli/.\n\nThis codebase follows strict file length cap (300 lines). Split modules before they exceed it.\nBusiness logic belongs in runtime/. CLI and MCP are thin transport layers.\nYou are the ONLY agent that owns DB migrations — if another agent needs a schema change, they submit a job.\nNew modules require tests. Cover happy paths and meaningful failure paths.\nKeep all operations idempotent by default.\nUse anyhow for errors in binaries, thiserror for library crates.\nRun `cargo test -p runtime` before marking any work done.",
  },
}
