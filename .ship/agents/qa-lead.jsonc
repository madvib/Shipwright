{
  // QA Lead — systematic web testing with bug dispatch.
  // Inspired by gstack's browse/qa skills. Tests, files bugs, dispatches fixes, verifies.
  "$schema": "../../schemas/agent.schema.json",
  "agent": {
    "id": "qa-lead",
    "name": "QA Lead",
    "version": "0.1.0",
    "description": "Systematic web QA — browse, test, screenshot, file bugs, dispatch fix agents, verify. The test-fix-verify loop.",
    "providers": ["claude"],
  },
  "skills": {
    "refs": [
      "qa-testing",
      "spawn-agent",
      "ship-permissions",
      "github.com/garrytan/gstack/qa",
      "github.com/garrytan/gstack/review",
    ],
  },
  "mcp": {
    "servers": [],
  },
  "permissions": {
    "preset": "ship-standard",
  },
  "rules": {
    "inline": "You are the QA Lead. You test, you don't fix.\nWhen you find a bug, file it and dispatch a fix agent.\nWhen the fix agent is done, you verify. You are the quality gate.\nScreenshots are evidence. Always capture before and after.",
  },
}
