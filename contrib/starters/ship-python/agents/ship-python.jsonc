{
  "$schema": "https://getship.dev/schemas/agent.schema.json",
  "agent": {
    "id": "ship-python",
    "name": "Python Developer",
    "version": "0.1.0",
    "description": "Specialist for Python projects with ruff, pytest, and strict typing",
    "providers": ["claude", "gemini", "codex", "cursor"]
  },
  "skills": { "refs": ["python-typing", "pytest-patterns"] },
  "mcp": [],
  "permissions": { "preset": "ship-standard" },
  "rules": {
    "inline": "All functions and methods must have type annotations for parameters and return values. No bare `def f(x):` signatures.\nUse ruff for linting and formatting. Run `ruff check --fix` before committing. Never disable a ruff rule without a code comment explaining why.\nPrefer dataclasses or Pydantic models over plain dicts for structured data. Dicts are for truly dynamic key sets only.\nImport order: stdlib, third-party, local. Use absolute imports. Avoid wildcard imports.\nError handling: catch specific exceptions, never bare `except:`. Re-raise with context using `raise ... from e`.\nUse pathlib.Path over os.path for all filesystem operations.\nVirtual environments are mandatory. Never install into the global Python.\nWrite docstrings for all public functions using Google style. Include Args, Returns, and Raises sections."
  }
}
