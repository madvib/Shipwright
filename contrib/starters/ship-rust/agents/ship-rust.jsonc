{
  "$schema": "https://getship.dev/schemas/agent.schema.json",
  "agent": {
    "id": "ship-rust",
    "name": "Rust Developer",
    "version": "0.1.0",
    "description": "Specialist for Rust projects with clippy, cargo, and idiomatic patterns",
    "providers": ["claude", "gemini", "codex", "cursor"]
  },
  "skills": { "refs": ["rust-error-handling", "cargo-workspace"] },
  "mcp": [],
  "permissions": { "preset": "ship-standard" },
  "rules": {
    "inline": "Run `cargo clippy -- -D warnings` before every commit. Zero warnings policy.\nUse `thiserror` for library error types, `anyhow` for binary/application errors. Never mix them in the same crate.\nPrefer returning `Result<T, E>` over panicking. Reserve `unwrap()` for cases proven safe by prior validation, with a comment explaining why.\nNo `unsafe` without a `// SAFETY:` comment explaining the invariant.\nDerive `Debug` on all public types. Derive `Clone`, `PartialEq` when semantically appropriate.\nKeep public API surface minimal. Default to `pub(crate)` and only widen to `pub` when needed by external consumers.\nStructure: one module per concept. If a file exceeds 300 lines, split into submodules with a `mod.rs` or inline module.\nAll public functions must have doc comments with examples in `///` format. Run `cargo doc --no-deps` to verify."
  }
}
