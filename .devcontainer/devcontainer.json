{
  "name": "Ship",
  "image": "ghcr.io/prulloac/base:ubuntu-24.04",

  "features": {
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers-extra/features/pnpm:2": {},
    "ghcr.io/guiyomh/features/just:0": {},
    "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {}
  },

  "onCreateCommand": "sudo chown -R vscode:vscode /usr/local/cargo/registry /usr/local/cargo/git /workspaces/ship/target 2>/dev/null; rustup target add wasm32-unknown-unknown && curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh && sudo apt-get update && sudo apt-get install -y tmux",
  "postCreateCommand": "pnpm install && cargo build -p ship-studio-cli -p mcp && cargo install --path apps/ship-studio-cli",
  "postStartCommand": "git pull --ff-only origin main 2>/dev/null || true && cargo install --path apps/ship-studio-cli 2>/dev/null || true",

  "mounts": [
    "source=ship-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=ship-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=ship-cargo-target,target=/workspaces/ship/target,type=volume",
    "source=ship-pnpm-store,target=/home/vscode/.local/share/pnpm/store,type=volume",
    "source=${localEnv:HOME}/.ship,target=/home/vscode/.ship,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dev/worktrees,target=/workspaces/worktrees,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached"
  ],

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:${containerWorkspaceFolder}/target/debug:/home/vscode/.local/bin",
    "PNPM_HOME": "/home/vscode/.local/share/pnpm",
    "NPM_CONFIG_STORE_DIR": "/home/vscode/.local/share/pnpm/store"
  },

  "forwardPorts": [3000, 3001, 3002, 7701, 51741],
  "portsAttributes": {
    "3000": { "label": "Ship Studio", "onAutoForward": "openBrowser" },
    "3001": { "label": "Ship Studio (alt)", "onAutoForward": "openBrowser" },
    "3002": { "label": "Vite HMR", "onAutoForward": "silent" },
    "7701": { "label": "Ship Server", "onAutoForward": "silent" },
    "51741": { "label": "Ship MCP", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "oxc.oxc-vscode",
        "bradlc.vscode-tailwindcss",
        "Anthropic.claude-code"
      ],
      "settings": {
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer",
          "editor.formatOnSave": true
        }
      }
    }
  },

  "remoteUser": "vscode"
}
