# Ship Studio — environment variables
# Copy to .env.local for local development. Never commit .env.local.

# ─── Cloudflare ───────────────────────────────────────────────────────────────
# Set via wrangler secrets or in Cloudflare dashboard for production.
# For local dev, wrangler.jsonc bindings are used instead.
CLOUDFLARE_ACCOUNT_ID=           # Your Cloudflare account ID
CLOUDFLARE_API_TOKEN=            # Token with Workers + D1 + Pages permissions

# ─── D1 Database ──────────────────────────────────────────────────────────────
# Binding name: DB (configured in wrangler.jsonc)
# Run `wrangler d1 create ship` to provision and paste the database_id into wrangler.jsonc.
# D1_DATABASE_ID is informational only — actual binding is resolved by wrangler at runtime.
D1_DATABASE_ID=                  # The D1 database UUID (for reference)

# ─── GitHub OAuth / API ───────────────────────────────────────────────────────
GITHUB_TOKEN=                    # Personal access token or OAuth app token for API calls
GITHUB_CLIENT_ID=                # OAuth App client ID (for better-auth GitHub provider)
GITHUB_CLIENT_SECRET=            # OAuth App client secret

# ─── Auth ─────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=              # Random secret >= 32 chars — run `openssl rand -hex 32`
BETTER_AUTH_URL=                 # Public URL of the app, e.g. https://ship-studio.com

# ─── App ──────────────────────────────────────────────────────────────────────
PUBLIC_APP_URL=                  # Same as BETTER_AUTH_URL in most deployments
