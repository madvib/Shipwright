# Copy to .dev.vars for local development (never commit .dev.vars)
# For staging/production, set these as Wrangler secrets:
#   wrangler secret put BETTER_AUTH_SECRET --env staging
#   wrangler secret put GITHUB_CLIENT_ID --env staging
#   etc.

# GitHub OAuth app credentials (https://github.com/settings/applications/new)
# Use separate OAuth apps per environment (different callback URLs)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Better Auth secret — also used as JWT signing key for /api/auth/token (HS256)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
