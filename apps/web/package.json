{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000 --host",
    "build": "vite build && node -e \"const fs=require('fs'),p=require('path');const src='../../packages/assets/public',dst='dist/client';fs.readdirSync(src).forEach(f=>{const s=p.join(src,f),d=p.join(dst,f);fs.existsSync(s)&&fs.lstatSync(s).isFile()&&fs.copyFileSync(s,d)})\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "cf:types": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy",
    "db:generate:auth": "drizzle-kit generate --config drizzle-auth.config.ts",
    "db:generate:registry": "drizzle-kit generate --config drizzle-registry.config.ts",
    "db:generate": "pnpm db:generate:auth && pnpm db:generate:registry"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@ship/compiler": "workspace:*",
    "@ship/primitives": "workspace:*",
    "@ship/ui": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/query-db-collection": "latest",
    "@tanstack/react-db": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.166.10",
    "@xyflow/react": "^12.10.1",
    "better-auth": "^1.5.3",
    "drizzle-orm": "^0.45.1",
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.75.0"
  }
}
