---

---

<section id="waitlist" class="relative px-10 py-40 overflow-hidden text-center">
  <!-- Brand-Aligned Glow -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-ship-accent/10 rounded-full blur-[120px] pointer-events-none animate-pulse duration-[4s]"
  >
  </div>

  <div class="relative z-10 max-w-2xl mx-auto">
    <div
      class="flex items-center justify-center gap-2 mb-8 text-[11px] font-mono tracking-[0.2em] uppercase text-ship-accent/80 animate-fade-up opacity-0"
    >
      <span class="w-6 h-px bg-ship-accent/40"></span>
      ACCESS REGISTRY
    </div>

    <h2
      class="mb-6 text-4xl sm:text-5xl md:text-6xl font-bold tracking-tighter font-display uppercase italic animate-fade-up opacity-0 [animation-delay:0.1s]"
    >
      Join the Alpha.
    </h2>
    <p
      class="mb-10 sm:mb-12 text-base sm:text-lg font-light leading-relaxed text-ship-dim animate-fade-up opacity-0 [animation-delay:0.2s] text-balance"
    >
      Ship is local-first and free to use.<br class="hidden sm:block" />
      Cloud sync and team features are paid — like Obsidian, but for your agentic
      workflow.
    </p>

    <div
      id="waitlist-form-container"
      class="animate-fade-up opacity-0 [animation-delay:0.3s]"
    >
      <form
        id="waitlist-form"
        class="flex flex-col sm:flex-row gap-3 sm:gap-4 max-w-md mx-auto mb-10 p-2 border-2 border-ship-border bg-ship-surface/30 rounded-2xl backdrop-blur-xl group hover:border-ship-accent/20 transition-all duration-500"
      >
        <input
          id="email-input"
          type="email"
          required
          placeholder="ENTER_EMAIL_ADDR"
          class="flex-1 px-5 py-4 text-sm font-mono transition-all bg-transparent border-none text-ship-text focus:outline-none placeholder:text-ship-dim/30 w-full"
        />
        <button
          type="submit"
          class="px-8 py-4 text-sm font-bold text-ship-bg transition-all rounded-xl bg-ship-accent hover:opacity-90 hover:-translate-y-px whitespace-nowrap shadow-xl shadow-ship-accent/10 w-full sm:w-auto"
        >
          JOIN WAITLIST
        </button>
      </form>

      <div id="form-msg" class="hidden text-sm font-mono mt-4"></div>

      <div
        class="flex items-center justify-center gap-3 text-[10px] font-mono text-ship-dim/80 uppercase tracking-widest mt-12"
      >
        <span
          class="w-2 h-2 rounded-full bg-ship-green animate-pulse shadow-[0_0_10px_rgba(var(--status-green),0.8)]"
        ></span>
        ALPHA_INTERNAL_PROTOCOLS_READY
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement;
  const msg = document.getElementById("form-msg");
  const container = document.getElementById("waitlist-form-container");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (document.getElementById("email-input") as HTMLInputElement)
      .value;

    try {
      const response = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      const data = await response.json();

      if (response.ok) {
        if (msg) {
          msg.textContent = "ACCESS_SECURED: CHECK_INBOX_SOON";
          msg.className = "text-ship-green font-bold animate-fade-in";
          msg.classList.remove("hidden");
          form.classList.add("opacity-0", "pointer-events-none");
        }
      } else {
        if (msg) {
          msg.textContent = `ERROR: ${data.error || "COULD_NOT_REGISTER"}`;
          msg.className = "text-red-400 font-bold";
          msg.classList.remove("hidden");
        }
      }
    } catch (err) {
      if (msg) {
        msg.textContent = "ERROR: NETWORK_FAILURE";
        msg.className = "text-red-400 font-bold";
        msg.classList.remove("hidden");
      }
    }
  });
</script>

<style>
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.2, 1, 0.2, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
      filter: blur(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
</style>
