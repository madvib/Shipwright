---

---

<section id="capabilities" class="px-10 py-32 bg-ship-bg">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div
      class="flex flex-col lg:flex-row items-end justify-between gap-8 mb-20"
    >
      <div class="max-w-2xl">
        <div
          class="flex items-center gap-2 mb-6 text-[11px] font-mono tracking-[0.2em] uppercase text-ship-accent/80"
        >
          <span class="w-6 h-px bg-ship-accent/40"></span>
          INFRASTRUCTURE & INTERFACES
        </div>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tighter font-display uppercase italic text-ship-text"
        >
          Core Capabilities.
        </h2>
        <p class="mt-4 sm:mt-6 text-base sm:text-xl font-light text-ship-dim">
          Branch-scoped memory. Granular permissions. Every interface you need.
          Ship provides the full infrastructure for agentic workflows —
          local-first, with optional team sync.
        </p>
      </div>
      <div class="hidden lg:block pb-2">
        <div
          class="px-4 py-2 border border-ship-border rounded-lg bg-ship-surface font-mono text-[10px] text-ship-dim tracking-widest uppercase font-bold"
        >
          STATUS: ALPHA_ACCESS
        </div>
      </div>
    </div>

    <!-- Main Grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-px overflow-hidden border rounded-2xl bg-ship-border border-ship-border shadow-2xl"
    >
      <!-- Interface Row: CLI, MCP, Desktop -->
      <div
        class="col-span-1 md:col-span-2 p-12 bg-ship-bg hover:bg-ship-surface group transition-all duration-500 flex flex-col lg:flex-row items-center gap-16 border-b border-ship-border"
      >
        <div class="flex-1">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 mb-8 text-[10px] font-mono tracking-widest uppercase border rounded bg-ship-accent/5 border-ship-accent/10 text-ship-accent font-bold"
          >
            MULTI-MODAL INTERFACES
          </div>
          <h3
            class="mb-4 text-3xl font-bold tracking-tighter font-display uppercase italic"
          >
            CLI, MCP, & Desktop GUI
          </h3>
          <p class="text-base leading-relaxed text-ship-dim font-light">
            Stay in the flow. Use the CLI for high-velocity terminal work, the
            Desktop app for visual planning/specs, or the MCP server to inject
            context directly into your preferred IDE agents.
          </p>

          <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div class="space-y-2">
              <div
                class="text-[10px] font-mono text-ship-accent uppercase tracking-widest font-bold"
              >
                CLI
              </div>
              <div class="text-[11px] text-ship-dim/60 font-light">
                Engineered for CI/CD and terminal power users.
              </div>
            </div>
            <div class="space-y-2">
              <div
                class="text-[10px] font-mono text-ship-blue uppercase tracking-widest font-bold"
              >
                MCP
              </div>
              <div class="text-[11px] text-ship-dim/60 font-light">
                Seamless IDE integration for Claude and beyond.
              </div>
            </div>
            <div class="space-y-2">
              <div
                class="text-[10px] font-mono text-ship-green uppercase tracking-widest font-bold"
              >
                GUI
              </div>
              <div class="text-[11px] text-ship-dim/60 font-light">
                Visual flow for release planning and specs.
              </div>
            </div>
          </div>
        </div>

        <div
          class="w-full lg:w-[460px] p-6 sm:p-8 border rounded-2xl bg-ship-bg/50 border-ship-border/50 font-mono text-[10px] sm:text-[11px] shadow-inner relative overflow-hidden group-hover:border-ship-accent/30 transition-all"
        >
          <div
            class="absolute top-0 right-0 p-4 opacity-20 group-hover:opacity-40 transition-opacity"
          >
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-ship-accent"
              ><circle cx="12" cy="12" r="10"></circle><path d="m16 12-4-4-4 4"
              ></path></svg
            >
          </div>
          <div class="space-y-3 sm:space-y-4">
            <div
              class="flex items-center gap-2 sm:gap-3 border-b border-ship-border/30 pb-3"
            >
              <span class="text-ship-accent font-bold">$</span>
              <span class="text-ship-text truncate"
                >ship start --workspace=api-refactor</span
              >
            </div>
            <div
              class="space-y-1.5 sm:space-y-2 text-ship-dim/60 text-[9px] sm:text-[10px]"
            >
              <div class="flex justify-between">
                <span>[MODULE] PERMISSIONS</span><span
                  class="text-ship-green uppercase">OK</span>
              </div>
              <div class="flex justify-between">
                <span>[MODULE] SKILLS</span><span class="text-ship-green"
                  >12</span>
              </div>
              <div class="flex justify-between">
                <span>[MODULE] MCP_SERVER</span><span class="text-ship-blue"
                  >SYNC:4000</span>
              </div>
            </div>
            <div class="pt-4">
              <div
                class="h-1 w-full bg-ship-surface rounded-full overflow-hidden"
              >
                <div class="h-full bg-ship-accent w-[75%] animate-pulse"></div>
              </div>
              <div
                class="mt-2 text-[8px] text-ship-dim/40 uppercase tracking-widest text-center italic"
              >
                Ship Engine active
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Permissions & Skills -->
      <div
        class="p-8 sm:p-12 bg-ship-bg hover:bg-ship-surface transition-all duration-500 group border-r border-ship-border"
      >
        <div
          class="w-10 h-10 sm:w-12 sm:h-12 mb-6 sm:mb-8 rounded-xl bg-ship-blue/10 flex items-center justify-center text-ship-blue border border-ship-blue/20"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg
          >
        </div>
        <h3
          class="mb-3 sm:mb-4 text-xl sm:text-2xl font-bold tracking-tighter font-display uppercase italic text-ship-text"
        >
          Permissions & Security
        </h3>
        <p
          class="text-sm sm:text-base leading-relaxed text-ship-dim font-light mb-6 sm:mb-8"
        >
          Granular control over what agents can see. Define scopes once; Ship
          enforces them across every provider, ensuring your source code remains
          secure.
        </p>
        <ul
          class="space-y-2 sm:space-y-3 font-mono text-[9px] sm:text-[10px] text-ship-dim/60 uppercase tracking-widest"
        >
          <li class="flex items-center gap-2 font-bold">
            <span class="w-1.5 h-1.5 rounded-full bg-ship-blue"></span> Branch-Scoped
            Access
          </li>
          <li class="flex items-center gap-2 font-bold">
            <span class="w-1.5 h-1.5 rounded-full bg-ship-blue"></span> Skill Injection
            Guards
          </li>
          <li class="flex items-center gap-2 font-bold">
            <span class="w-1.5 h-1.5 rounded-full bg-ship-blue"></span> Tool Execution
            Policies
          </li>
        </ul>
      </div>

      <!-- Sync & Import/Export -->
      <div
        class="p-12 bg-ship-bg hover:bg-ship-surface transition-all duration-500 group"
      >
        <div
          class="w-12 h-12 mb-8 rounded-xl bg-ship-green/10 flex items-center justify-center text-ship-green border border-ship-green/20"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 2v6h-6"></path><path d="M3 12a9 9 0 0 1 15-6.7L21 8"
            ></path><path d="M3 22v-6h6"></path><path
              d="M21 12a9 9 0 0 1-15 6.7L3 16"></path></svg
          >
        </div>
        <h3
          class="mb-4 text-2xl font-bold tracking-tighter font-display uppercase italic text-ship-text"
        >
          Provider Sync
        </h3>
        <p class="text-base leading-relaxed text-ship-dim font-light mb-8">
          Don't get locked in. Import existing `.cursorrules` or `.clauderules`,
          and export Ship configurations to any custom format. We play nice with
          your current stack.
        </p>
        <div
          class="p-4 rounded-xl bg-ship-bg border border-ship-border flex items-center justify-between group-hover:border-ship-green/30 transition-all font-mono text-[10px] uppercase font-bold text-ship-dim"
        >
          <span>CONFIG_ADAPTER</span>
          <span class="text-ship-green">v1.2.4_READY</span>
        </div>
      </div>
    </div>
  </div>
</section>
