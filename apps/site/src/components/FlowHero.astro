---
import { IntentMock } from "./IntentMock";
import { OutputMock } from "./OutputMock";

import Logo from "./Logo.astro";

const features = [
  {
    label: "Vision → Features → Spec",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>`,
    color: "text-ship-accent",
    bgColor: "bg-ship-accent/10",
    borderColor: "border-ship-accent/20",
    textStyle: "italic",
  },
  {
    label: "Ship Runtime",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="overflow: visible;"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 1 1-3.5 1.27l-.12-.1a2 2 0 0 0-2.85.3l-.31.41a2 2 0 0 0 .3 2.85l.1.1a2 2 0 1 1-1.27 3.5h-.18a2 2 0 0 0-2 2v.44a2 2 0 0 0 2 2h.18a2 2 0 1 1 1.27 3.5l-.1.1a2 2 0 0 0-.3 2.85l.31.41a2 2 0 0 0 2.85-.3l.12-.1a2 2 0 1 1 3.5 1.27v.18a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 1 1 3.5-1.27l.12.1a2 2 0 0 0 2.85-.3l.31-.41a2 2 0 0 0-.3-2.85l-.1-.1a2 2 0 1 1 1.27-3.5h.18a2 2 0 0 0 2-2v-.44a2 2 0 0 0-2-2h-.18a2 2 0 1 1-1.27-3.5l.1-.1a2 2 0 0 0 .3-2.85l-.31-.41a2 2 0 0 0-2.85.3l-.12.1a2 2 0 1 1-3.5-1.27V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
    color: "text-ship-accent",
    bgColor: "bg-ship-accent/10",
    borderColor: "border-ship-accent/20",
    textStyle: "italic text-ship-blue",
  },
  {
    label: "AGENTS.md, .CLAUDE.md, etc.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V10Z"/><path d="M12 18v-4"/><path d="M8 10h.01"/><path d="M16 10h.01"/><path d="M9 2h6"/><path d="M12 2v4"/></svg>`,
    color: "text-ship-green",
    bgColor: "bg-ship-green/10",
    borderColor: "border-ship-green/20",
    textStyle: "font-mono",
  },
];
---

<section
  class="relative w-full min-h-screen overflow-hidden bg-ship-bg flex flex-col items-center justify-center px-6 pt-24 pb-16"
>
  <!-- Ambient background glow -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-ship-accent/5 blur-[160px] pointer-events-none"
  >
  </div>

  <!-- Hero headline -->
  <div class="relative z-10 text-center mb-8 hero-reveal">
    <!-- Trust badge -->
    <div
      class="inline-flex items-center gap-2 mb-6 px-3 py-1 rounded-full border border-ship-accent/20 bg-ship-accent/5 font-mono text-[10px] tracking-widest uppercase text-ship-accent/70 font-bold"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-ship-green animate-pulse"></span>
      Local-first &middot; Free to start &middot; Sync is paid
    </div>
    <h1
      class="text-3xl sm:text-4xl md:text-5xl lg:text-5xl font-bold tracking-tighter font-display leading-[1] uppercase italic mb-3"
    >
      Every agent,<br /><span class="text-ship-accent">always briefed.</span>
    </h1>
    <p
      class="text-sm md:text-base font-light text-ship-dim max-w-[480px] mx-auto leading-relaxed"
    >
      Ship keeps your AI tools in sync with your project — per branch, per
      feature, per decision. Write your intent once. Claude, Codex, and Gemini
      all read it.
    </p>
  </div>

  <!-- The Flow Visualization -->
  <div class="relative z-10 w-full max-w-[1100px]">
    <!-- Flow labels -->
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_auto_1fr] gap-4 lg:gap-0 items-stretch"
    >
      <!-- LEFT: Intent Panel -->
      <div class="flow-panel flow-panel-delay-1">
        <div
          class="h-full p-5 rounded-2xl border border-ship-border/40 bg-ship-surface/30 backdrop-blur-sm"
        >
          <div class="flex items-center justify-between mb-4">
            <div
              class="font-mono text-[9px] tracking-[0.2em] uppercase text-ship-dim font-bold"
            >
              Your Intent
            </div>
            <div
              class="font-mono text-[8px] tracking-widest uppercase text-ship-accent/60 font-bold"
            >
              Input
            </div>
          </div>
          <IntentMock client:load />
        </div>
      </div>

      <!-- MIDDLE: Compiler Pipeline -->
      <div
        class="flex items-center justify-center lg:px-6 flow-panel flow-panel-delay-2"
      >
        <div class="flex flex-col items-center gap-4 py-6 lg:py-0">
          <!-- Top arrow -->
          <div class="hidden lg:block">
            <svg
              width="24"
              height="24"
              viewBox="0 0 32 32"
              fill="none"
              class="text-ship-accent/30 -rotate-90"
            >
              <path
                d="M8 16H24M24 16L18 10M24 16L18 22"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>

          <!-- Compiler Core -->
          <div class="relative">
            <div
              class="w-32 h-32 md:w-44 md:h-44 rounded-2xl border border-ship-accent/20 bg-ship-bg/80 backdrop-blur-xl flex flex-col items-center justify-center relative overflow-hidden"
            >
              <!-- Subtle grid background -->
              <div
                class="absolute inset-0 opacity-[0.03]"
                style="background-image: linear-gradient(var(--primary) 1px, transparent 1px), linear-gradient(90deg, var(--primary) 1px, transparent 1px); background-size: 16px 16px;"
              >
              </div>

              <div class="relative z-10 flex flex-col items-center">
                <div class="w-12 h-12 md:w-16 md:h-16 mb-2">
                  <Logo
                    class="w-full h-full drop-shadow-[0_0_12px_rgba(232,168,34,0.25)]"
                    idPrefix="hero"
                  />
                </div>
                <div
                  class="text-[7px] md:text-[8px] font-mono font-bold text-ship-accent tracking-[.3em] md:tracking-[0.4em] uppercase"
                >
                  Engine
                </div>
                <div class="w-6 h-px bg-ship-accent/30 mx-auto mt-2 mb-2"></div>
                <div
                  class="text-[8px] font-mono text-ship-dim/60 tracking-wider uppercase"
                >
                  Compiler
                </div>
              </div>

              <!-- Corner accents -->
              <div
                class="absolute top-0 left-0 w-3 h-3 border-t border-l border-ship-accent/30 rounded-tl-lg"
              >
              </div>
              <div
                class="absolute top-0 right-0 w-3 h-3 border-t border-r border-ship-accent/30 rounded-tr-lg"
              >
              </div>
              <div
                class="absolute bottom-0 left-0 w-3 h-3 border-b border-l border-ship-accent/30 rounded-bl-lg"
              >
              </div>
              <div
                class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-ship-accent/30 rounded-br-lg"
              >
              </div>
            </div>

            <!-- Status indicator -->
            <div
              class="absolute -bottom-2.5 left-1/2 -translate-x-1/2 flex items-center gap-1.5 px-2.5 py-0.5 bg-ship-bg border border-ship-accent/20 rounded-full"
            >
              <span class="w-1 h-1 rounded-full bg-ship-green"></span>
              <span
                class="font-mono text-[7px] text-ship-dim tracking-widest uppercase font-bold"
                >Compiling</span
              >
            </div>
          </div>

          <!-- Bottom arrow -->
          <div class="hidden lg:block">
            <svg
              width="24"
              height="24"
              viewBox="0 0 32 32"
              fill="none"
              class="text-ship-green/30 rotate-90"
            >
              <path
                d="M8 16H24M24 16L18 10M24 16L18 22"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- RIGHT: Output Panel -->
      <div class="flow-panel flow-panel-delay-3">
        <div
          class="h-full p-5 rounded-2xl border border-ship-border/40 bg-ship-surface/30 backdrop-blur-sm"
        >
          <div class="flex items-center justify-between mb-4">
            <div
              class="font-mono text-[9px] tracking-[0.2em] uppercase text-ship-dim font-bold"
            >
              Agent Context
            </div>
            <div
              class="font-mono text-[8px] tracking-widest uppercase text-ship-green/60 font-bold"
            >
              Output
            </div>
          </div>
          <OutputMock client:load />
        </div>
      </div>
    </div>

    <!-- Flow description strip -->
    <div
      class="mt-16 flex flex-col md:flex-row items-center justify-center gap-6 md:gap-10 text-center flow-panel flow-panel-delay-4"
    >
      {
        features.map((feature) => (
          <div class="flex items-center gap-3">
            <div
              class={`w-9 h-9 rounded-lg ${feature.bgColor} border ${feature.borderColor} flex items-center justify-center ${feature.color}`}
              set:html={feature.icon}
            />
            <span
              class={`text-[11px] sm:text-xs text-ship-dim font-light tracking-wide ${feature.textStyle}`}
            >
              {feature.label}
            </span>
          </div>
        ))
      }
    </div>
  </div>

  <!-- CTA buttons -->
  <div
    class="relative z-10 mt-12 flex flex-wrap items-center justify-center gap-4 hero-reveal-delay"
  >
    <a
      href="#waitlist"
      class="px-8 py-3 text-sm font-bold text-ship-bg bg-ship-accent rounded-xl hover:opacity-90 hover:-translate-y-0.5 transition-all shadow-xl shadow-ship-accent/10"
    >
      JOIN THE ALPHA
    </a>
    <a
      href="#context-sync"
      class="px-8 py-3 text-sm font-medium text-ship-dim border border-ship-border rounded-xl hover:bg-ship-surface hover:text-ship-text transition-all"
    >
      VIEW SPECS
    </a>
  </div>
</section>

<style>
  .hero-reveal {
    animation: heroReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .hero-reveal-delay {
    animation: heroReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
    opacity: 0;
  }

  @keyframes heroReveal {
    from {
      opacity: 0;
      transform: translateY(16px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .flow-panel {
    animation: panelSlide 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .flow-panel-delay-1 {
    animation-delay: 0.2s;
  }
  .flow-panel-delay-2 {
    animation-delay: 0.35s;
  }
  .flow-panel-delay-3 {
    animation-delay: 0.5s;
  }
  .flow-panel-delay-4 {
    animation-delay: 0.65s;
  }

  @keyframes panelSlide {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
