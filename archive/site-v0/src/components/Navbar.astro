---
import Logo from "./Logo.astro";
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-100 flex items-center justify-between px-10 py-5 transition-all duration-300 border-b border-transparent"
>
  <a
    href="/"
    class="nav-logo flex items-center gap-2.5 text-xl font-bold tracking-tighter font-display text-ship-text group"
  >
    <Logo class="h-7 w-auto" idPrefix="nav" />
    SHIP
  </a>

  <ul class="flex items-center gap-4 sm:gap-10 list-none">
    <li class="hidden md:block">
      <a
        href="/#the-engine"
        class="text-[13px] font-medium transition-colors text-ship-dim hover:text-ship-text"
        >ENGINE</a
      >
    </li>
    <li class="hidden md:block">
      <a
        href="/agents"
        class="text-[13px] font-medium transition-colors text-ship-dim hover:text-ship-text"
        >AGENTS</a
      >
    </li>
    <li class="hidden md:block">
      <a
        href="/#capabilities"
        class="text-[13px] font-medium transition-colors text-ship-dim hover:text-ship-text"
        >CAPABILITIES</a
      >
    </li>
    <li>
      <a
        href="#waitlist"
        class="px-4 py-2 sm:px-5 sm:py-2 text-[12px] sm:text-[13px] font-semibold transition-all rounded-md bg-ship-accent text-ship-bg hover:opacity-90 hover:-translate-y-px shadow-lg shadow-ship-accent/10 whitespace-nowrap"
      >
        JOIN ALPHA
      </a>
    </li>
  </ul>
</nav>

<script>
  const nav = document.querySelector("#main-nav");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      nav?.classList.add("glass", "py-4", "border-ship-border");
      nav?.classList.remove("py-5", "border-transparent");
    } else {
      nav?.classList.remove("glass", "py-4", "border-ship-border");
      nav?.classList.add("py-5", "border-transparent");
    }
  });
</script>

<style>
  .nav-logo {
    letter-spacing: -0.05em;
  }
</style>
