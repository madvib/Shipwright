---
import LogoSecondary from "./LogoSecondary.astro";

const steps = [
  {
    num: "01",
    title: "Intent Snapshot",
    desc: "Document features and specifications in Ship with an attached agent mode (ie. Next.js Agent, SQL expert, or custom).",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ship-accent"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>`,
  },
  {
    num: "02",
    title: "Context Generation",
    desc: "Ship Runtime automatically generates branch-scoped context and Agent configuration files (.CLAUDE, .codex, .gemini) tailored to the active Spec.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ship-accent"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    num: "03",
    title: "MCP Orchestration",
    desc: "The correct MCP servers, skills, and rules are injected with granular permissions. Your agent wakes up fully equipped.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ship-accent" style="overflow: visible;"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 1 1-3.5 1.27l-.12-.1a2 2 0 0 0-2.85.3l-.31.41a2 2 0 0 0 .3 2.85l.1.1a2 2 0 1 1-1.27 3.5h-.18a2 2 0 0 0-2 2v.44a2 2 0 0 0 2 2h.18a2 2 0 1 1 1.27 3.5l-.1.1a2 2 0 0 0-.3 2.85l.31.41a2 2 0 0 0 2.85-.3l.12-.1a2 2 0 1 1 3.5 1.27v.18a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 1 1 3.5-1.27l.12.1a2 2 0 0 0 2.85-.3l.31-.41a2 2 0 0 0-.3-2.85l-.1-.1a2 2 0 1 1 1.27-3.5h.18a2 2 0 0 0 2-2v-.44a2 2 0 0 0-2-2h-.18a2 2 0 1 1-1.27-3.5l.1-.1a2 2 0 0 0 .3-2.85l-.31-.41a2 2 0 0 0-2.85.3l-.12.1a2 2 0 1 1-3.5-1.27V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
];
---

<section
  id="the-engine"
  class="px-10 py-32 bg-ship-bg border-y border-ship-border/30"
>
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-24">
      <div
        class="flex items-center justify-center gap-2 mb-6 text-[11px] font-mono tracking-[0.2em] uppercase text-ship-accent/80"
      >
        <span class="w-6 h-px bg-ship-accent/40"></span>
        AUTOMATED CONTEXT ORCHESTRATION
        <span class="w-6 h-px bg-ship-accent/40"></span>
      </div>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tighter font-display uppercase italic text-ship-text"
      >
        One Spec. Every Tool Reads It.
      </h2>
      <p
        class="mt-4 sm:mt-6 text-base sm:text-xl font-light text-ship-dim max-w-2xl mx-auto"
      >
        Write your intent in Ship once. The engine compiles it into
        branch-scoped context files for every AI tool you use — automatically,
        on every checkout.
      </p>
    </div>

    <!-- 3-Step Process Logic -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-px overflow-hidden border-2 rounded-2xl bg-ship-border border-ship-border shadow-2xl mb-24"
    >
      {
        steps.map((step) => (
          <div class="relative p-6 sm:p-10 bg-ship-bg hover:bg-ship-surface group transition-all duration-500">
            <div class="mb-4 sm:mb-6 font-mono text-[10px] sm:text-[11px] tracking-widest text-ship-dim/40 group-hover:text-ship-accent transition-colors font-bold">
              STEP_{step.num}
            </div>
            <div
              class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 mb-4 sm:mb-6 rounded-xl bg-ship-surface border border-ship-border group-hover:border-ship-accent/20 transition-all group-hover:scale-110"
              set:html={step.icon}
            />
            <h3 class="mb-2 sm:mb-3 text-base sm:text-lg font-bold tracking-tight font-display uppercase italic">
              {step.title}
            </h3>
            <p class="text-xs sm:text-sm leading-relaxed text-ship-dim font-light">
              {step.desc}
            </p>
            <div class="absolute bottom-0 left-0 w-full h-[2px] bg-ship-accent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          </div>
        ))
      }
    </div>

    <!-- Animated Flow Visualization -->
    <div
      class="relative min-h-[500px] flex flex-col items-center justify-center bg-ship-surface/10 rounded-3xl border border-ship-border/50 p-12 overflow-hidden"
    >
      <!-- Decoration -->
      <div
        class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none"
      >
        <div
          class="w-[800px] h-[800px] border border-ship-accent rounded-full animate-pulse"
        >
        </div>
      </div>

      <div
        class="relative z-10 w-full flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-8"
      >
        <!-- 1. INPUT -->
        <div class="w-full lg:w-64 space-y-4 animate-reveal-1">
          <div
            class="text-[9px] sm:text-[10px] font-mono text-ship-dim uppercase tracking-[0.2em] mb-4 font-bold text-center lg:text-left"
          >
            WORKSPACE_INPUT
          </div>
          <div
            class="p-4 sm:p-5 rounded-2xl border border-ship-accent/40 bg-ship-accent/5 shadow-lg shadow-ship-accent/5 flex items-center justify-between group cursor-pointer hover:bg-ship-accent/10 transition-all"
          >
            <div class="flex items-center gap-3 font-display">
              <div
                class="w-2 sm:w-2.5 h-2 sm:h-2.5 rounded-full bg-ship-accent animate-pulse"
              >
              </div>
              <span
                class="text-[12px] sm:text-sm font-bold tracking-tight text-ship-text"
                >WORKSPACE_SYNC</span
              >
            </div>
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-ship-accent"
              ><polyline points="9 18 15 12 9 6"></polyline></svg
            >
          </div>
          <p
            class="text-[9px] sm:text-[10px] text-ship-dim font-light leading-tight mt-4 text-center lg:text-left italic"
          >
            "Ship manages your agent config for you, so you don't need to track
            12 different files."
          </p>
        </div>

        <!-- FLOW 1 -->
        <div class="hidden lg:flex flex-col items-center">
          <div
            class="lg:w-24 lg:h-px bg-gradient-to-r from-ship-accent/50 to-transparent relative"
          >
            <div
              class="absolute top-1/2 left-0 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-ship-accent shadow-[0_0_15px_var(--primary)] animate-flow-step-1"
            >
            </div>
          </div>
        </div>

        <!-- 2. SHIP ENGINE -->
        <div class="relative animate-reveal-2 scale-90 sm:scale-100">
          <div
            class="w-40 h-40 sm:w-52 sm:h-52 rounded-[2rem] sm:rounded-[2.5rem] border-2 border-ship-accent/30 bg-ship-bg flex flex-col items-center justify-center shadow-2xl shadow-ship-accent/10 relative overflow-hidden group"
          >
            <div
              class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(var(--primary-rgb),0.15),transparent)] animate-engine-pulse"
            >
            </div>

            <div class="relative z-10 flex flex-col items-center">
              <div class="w-16 h-16 md:w-20 md:h-20 mb-2">
                <LogoSecondary
                  class="w-full h-full drop-shadow-[0_0_15px_rgba(168,85,247,0.3)]"
                  idPrefix="engine"
                />
              </div>
              <div
                class="text-[8px] sm:text-[9px] font-mono text-ship-accent tracking-[.4em] uppercase font-bold italic"
              >
                Engine
              </div>
            </div>

            <!-- Orbiting dots -->
            <div class="absolute inset-0 animate-spin-slow">
              <div
                class="absolute top-4 left-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-ship-accent shadow-[0_0_10px_var(--primary)]"
              >
              </div>
            </div>
          </div>

          <!-- Compiling Tag -->
          <div
            class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1.5 rounded-full bg-ship-bg border border-ship-border shadow-2xl flex items-center gap-2"
          >
            <span class="flex h-2 w-2 relative">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-ship-green opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-ship-green"
              ></span>
            </span>
            <span
              class="text-[10px] font-mono text-ship-dim uppercase tracking-widest font-bold"
              >Compiling</span
            >
          </div>
        </div>

        <!-- FLOW 2 -->
        <div class="hidden lg:flex flex-col items-center">
          <div
            class="lg:w-24 lg:h-px bg-gradient-to-r from-ship-accent/50 to-transparent relative"
          >
            <div
              class="absolute top-1/2 left-0 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-ship-accent shadow-[0_0_15px_var(--primary)] animate-flow-step-2"
            >
            </div>
          </div>
        </div>

        <!-- 3. OUTPUT -->
        <div class="w-full lg:w-80 space-y-4 animate-reveal-3">
          <div
            class="text-[9px] sm:text-[10px] font-mono text-ship-dim uppercase tracking-[0.2em] mb-4 font-bold text-center lg:text-left"
          >
            AGENT_CONFIG_OUTPUT
          </div>
          <div class="grid grid-cols-2 gap-2 sm:gap-3">
            <div
              class="p-3 sm:p-4 rounded-xl border border-ship-green/30 bg-ship-green/5 flex flex-col gap-2"
            >
              <div class="text-ship-green">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                  ></path><polyline points="14 2 14 8 20 8"></polyline></svg
                >
              </div>
              <div
                class="text-[10px] sm:text-[11px] font-bold text-ship-text font-display"
              >
                .CLAUDE
              </div>
            </div>

            <div
              class="p-3 sm:p-4 rounded-xl border border-ship-green/30 bg-ship-green/5 flex flex-col gap-2"
            >
              <div class="text-ship-green">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
                  ></path></svg
                >
              </div>
              <div
                class="text-[10px] sm:text-[11px] font-bold text-ship-text font-display"
              >
                .codex/
              </div>
            </div>

            <div
              class="p-3 sm:p-4 rounded-xl border border-ship-blue/30 bg-ship-blue/5 flex flex-col gap-2"
            >
              <div class="text-ship-blue">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
                  ></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"
                  ></polyline><line x1="12" y1="22.08" x2="12" y2="12"
                  ></line></svg
                >
              </div>
              <div
                class="text-[10px] sm:text-[11px] font-bold text-ship-text font-display"
              >
                .gemini
              </div>
            </div>

            <div
              class="p-3 sm:p-4 rounded-xl border border-ship-accent/30 bg-ship-accent/5 flex flex-col gap-2"
            >
              <div class="text-ship-accent">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"
                  ></path><path d="m14.5 4-5 16"></path></svg
                >
              </div>
              <div
                class="text-[10px] sm:text-[11px] font-bold text-ship-text font-display"
              >
                .agents
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer Bar -->
      <div
        class="mt-16 pt-8 border-t border-ship-border/30 w-full flex flex-col md:flex-row items-center justify-center gap-8 font-mono text-[10px] text-ship-dim/60 uppercase tracking-widest font-bold"
      >
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-ship-green"></div>
          AUTO_SYNC ACTIVE
        </div>
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-ship-accent"></div>
          SCOPED ENVIRONMENTS
        </div>
        <div class="flex items-center gap-2 text-ship-text">
          <div class="w-1.5 h-1.5 rounded-full bg-ship-blue"></div>
          SINGLE_SOURCE_TRUTH
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes flow-step-1 {
    0% {
      left: 0;
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.4);
    }
    5% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    25% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
      left: 100%;
    }
    30%,
    100% {
      opacity: 0;
      left: 100%;
    }
  }

  @keyframes flow-step-2 {
    0%,
    35% {
      left: 0;
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.4);
    }
    40% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    60% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
      left: 100%;
    }
    65%,
    100% {
      opacity: 0;
      left: 100%;
    }
  }

  .animate-flow-step-1 {
    animation: flow-step-1 3.5s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }

  .animate-flow-step-2 {
    animation: flow-step-2 3.5s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }

  .animate-engine-pulse {
    animation: enginePulse 2s ease-in-out infinite;
  }

  @keyframes enginePulse {
    0%,
    100% {
      opacity: 0.15;
      transform: scale(1);
    }
    50% {
      opacity: 0.25;
      transform: scale(1.05);
    }
  }

  .animate-spin-slow {
    animation: spin 12s linear infinite;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-reveal-1 {
    animation: reveal 0.8s ease-out forwards;
  }
  .animate-reveal-2 {
    animation: reveal 0.8s ease-out 0.4s forwards;
    opacity: 0;
  }
  .animate-reveal-3 {
    animation: reveal 0.8s ease-out 0.8s forwards;
    opacity: 0;
  }
</style>
