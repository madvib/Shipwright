---

---

<section
  class="px-6 py-32 relative overflow-hidden bg-ship-bg border-y border-ship-border/30"
>
  <div
    class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center"
  >
    <!-- Left: Problem Statement -->
    <div class="space-y-8 animate-fade-in opacity-0">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 font-mono text-[10px] tracking-widest text-ship-accent border border-ship-accent/30 rounded-full bg-ship-accent/5 font-bold uppercase"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-ship-accent"></span>
        The Missing Layer
      </div>
      <h2
        class="text-4xl md:text-5xl font-display font-bold tracking-tighter leading-tight italic uppercase"
      >
        Agents Forget.<br /><span
          class="text-ship-dim not-italic capitalize text-3xl md:text-4xl"
          >Every session starts from scratch.</span
        >
      </h2>
      <p class="text-lg text-ship-dim font-light leading-relaxed max-w-md">
        Re-explaining the project, re-establishing context, re-discovering what
        was decided last week. The AI tools aren't the problem.
      </p>
      <p class="text-lg text-ship-dim font-light leading-relaxed max-w-md">
        <strong class="text-ship-text font-medium">Ship</strong> is persistent project
        memory — per-branch context that every AI tool reads automatically, without
        being re-briefed.
      </p>
    </div>

    <!-- Right: Terminal Demo -->
    <div class="terminal-wrap animate-fade-up opacity-0 [animation-delay:0.4s]">
      <div
        class="relative overflow-hidden border-2 rounded-xl bg-[var(--background)] border-[var(--border)] terminal group hover:border-[var(--primary)]/30 transition-all duration-500 shadow-2xl"
      >
        <!-- Glow effect -->
        <div
          class="absolute inset-0 pointer-events-none bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"
        >
        </div>

        <!-- Terminal Header -->
        <div
          class="flex items-center gap-3 px-5 py-4 border-b bg-[color-mix(in_oklch,var(--background)_95%,transparent)] border-[var(--border)]"
        >
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-[var(--muted)]"></div>
            <div class="w-3 h-3 rounded-full bg-[var(--muted)]"></div>
            <div class="w-3 h-3 rounded-full bg-[var(--muted)]"></div>
          </div>
          <span
            class="ml-2 font-mono text-[11px] text-[var(--muted-foreground)] uppercase tracking-widest font-bold"
            >zsh — ship_engine</span
          >
        </div>

        <!-- Terminal Content -->
        <div
          class="p-8 font-mono text-sm leading-relaxed min-h-[380px] bg-[color-mix(in_oklch,var(--background)_50%,transparent)]"
        >
          <div class="flex gap-4 mb-4">
            <span class="text-[var(--primary)] select-none font-bold">❯</span>
            <span class="text-[var(--foreground)]">ship init</span>
          </div>

          <div class="mb-6 space-y-1">
            <div class="flex gap-3 text-[var(--muted-foreground)]">
              <span class="text-[var(--status-blue)] font-bold">[INFO]</span>
              <span
                >Initializing Ship in <span class="text-[var(--foreground)]"
                  >/Users/madvib/dev/ship-project</span
                ></span
              >
            </div>
            <div class="flex gap-3 text-[var(--muted-foreground)]">
              <span class="text-[var(--status-blue)] font-bold">[INFO]</span>
              <span>Mapping project identity...</span>
            </div>
            <div class="flex gap-3 text-[var(--status-green)]">
              <span class="font-bold">[SUCCESS]</span>
              <span>Project context synthesized. Tracking 128 files.</span>
            </div>
          </div>

          <div class="flex gap-4 mb-4">
            <span class="text-[var(--primary)] select-none font-bold">❯</span>
            <span class="text-[var(--foreground)]"
              >ship feature start <span class="text-[var(--primary)]"
                >auth-refactor</span
              ></span
            >
          </div>

          <div
            class="mb-6 space-y-1 pl-7 border-l-2 border-[var(--primary)]/20"
          >
            <div class="text-[var(--muted-foreground)]">
              Creating branch <span
                class="text-[var(--primary)] font-bold opacity-90"
                >feature/auth-refactor</span
              >...
            </div>
            <div class="text-[var(--muted-foreground)]">
              Generating branch-specific context...
            </div>
            <div class="flex items-center gap-2 mt-2">
              <span
                class="bg-[var(--primary)]/10 text-[var(--primary)] px-2 py-0.5 rounded text-[10px] border border-[var(--primary)]/20 font-bold uppercase tracking-wider"
                >Synced</span
              >
              <span class="text-[var(--muted-foreground)] text-xs py-0.5 italic"
                >MCP registry mapped</span
              >
            </div>
          </div>

          <div class="flex gap-4 mt-6">
            <span class="text-[var(--primary)] select-none font-bold">❯</span>
            <div
              class="inline-block w-2.5 h-6 bg-[var(--primary)] align-bottom animate-cursor-blink shadow-[0_0_15px_rgba(var(--primary),0.5)]"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-cursor-blink {
    animation: cursorBlink 1.2s step-end infinite;
  }

  @keyframes cursorBlink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.2, 1, 0.2, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
      filter: blur(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
</style>
