{
    "extends": "astro/tsconfigs/strict",
    "include": [
        ".astro/types.d.ts",
        "**/*"
    ],
    "exclude": [
        "dist"
    ],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@ui/*": [
                "../crates/ui/src/*"
            ],
            "@/*": [
                "../crates/ui/src/*"
            ]
        },
        "types": [
            "./worker-configuration.d.ts",
            "node"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": "react"
    }
}