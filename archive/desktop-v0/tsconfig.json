{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "baseUrl": ".",
    "skipLibCheck": true,
    "types": [
      "vite/client",
      "react",
      "react-dom"
    ],
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ship/primitives": [
        "../../packages/primitives/src/index.tsx"
      ],
      "@ship/primitives/*": [
        "../../packages/primitives/src/*"
      ],
      "@ship/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@ship/ui/*": [
        "../../packages/ui/src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}