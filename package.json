{
  "name": "ship-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "test": "pnpm --filter web test",
    "test:rust": "cargo test",
    "typecheck": "pnpm --filter web exec tsc --noEmit",
    "wasm": "wasm-pack build crates/core/compiler --target web --out-dir ../../../packages/compiler --out-name compiler -- --features wasm",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "db:migrate": "cd apps/web && npx wrangler d1 migrations apply ship --local",
    "cf:types": "cd apps/web && npx wrangler types",
    "cf:deploy": "pnpm --filter web deploy"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vite-plus": "^0.1.11"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  },
  "dependencies": {
    "@tiptap/core": "^3.21.0",
    "@tiptap/extension-bubble-menu": "^3.21.0",
    "@tiptap/extension-code-block-lowlight": "^3.21.0",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-table": "^3.21.0",
    "@tiptap/extension-task-item": "^3.21.0",
    "@tiptap/extension-task-list": "^3.21.0",
    "@tiptap/extension-typography": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "lowlight": "^3.3.0",
    "tiptap-markdown": "^0.9.0"
  }
}
